# ─────────────────────────────────────────────────────────────────────────────
# Vantage Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (required for auth + database — Step 2)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only — admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (required for payments — Step 5)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App config
NEXT_PUBLIC_APP_URL=https://portal.vantagestrat.co
